{
  "name": "sicose",
  "version": "1.0.0",
  "description": "Sistema web para la digitalizacion y gestion de pagos de servicios publicos en Juntas Auxiliares gubernamentales del estado de Puebla.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev": "concurrently -c \"cyan,magenta\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "lint": "npm run lint --prefix frontend && npm run lint --prefix backend",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reing01/SiCoSe.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Reing01/SiCoSe/issues"
  },
  "homepage": "https://github.com/Reing01/SiCoSe#readme",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
