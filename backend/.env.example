# Base de datos Supabase / PostgreSQL
# DATABASE_URL usa el pooler de Supabase para la app.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL usa conexion directa para migraciones Prisma.
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Cache / Sesiones
REDIS_URL="rediss://user:pass@host:port"

# Seguridad
JWT_SECRET="mi_secreto_super_seguro_para_desarrollo_123"
JWT_EXPIRES_IN="8h"
REFRESH_TOKEN_EXPIRES="7d"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="10"
RATE_LIMIT_EMAIL_WINDOW_MS="300000"
RATE_LIMIT_EMAIL_MAX="5"

# Infraestructura Supabase
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_KEY="<service-role-key>"
SUPABASE_STORAGE_BUCKET="comprobantes"

# Configuracion
CORS_ORIGIN="https://sicose.vercel.app"
NODE_ENV="development"
