{
  "info": {
    "name": "SiCoSe - Pagos",
    "description": "Endpoint para registrar pagos en efectivo y verificar auditoria.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login tesorero",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"gertrudis@sicose.test\",\n  \"password\": \"SiCoSe2026!\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "Registrar pago en efectivo",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"metodo\": \"efectivo\",\n  \"ciudadano_id\": \"{{ciudadano_id}}\",\n  \"adeudo_id\": \"{{adeudo_id}}\",\n  \"monto\": 45.5\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/pagos",
          "host": ["{{base_url}}"],
          "path": ["api", "pagos"]
        },
        "description": "Registra un pago, genera folio SCS-YYYY-XXXXXX, marca el adeudo como pagado y crea auditoria."
      }
    },
    {
      "name": "Registrar pago duplicado - espera 409",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"metodo\": \"efectivo\",\n  \"ciudadano_id\": \"{{ciudadano_id}}\",\n  \"adeudo_id\": \"{{adeudo_id}}\",\n  \"monto\": 45.5\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/pagos",
          "host": ["{{base_url}}"],
          "path": ["api", "pagos"]
        },
        "description": "Reutiliza el mismo adeudo_id de un pago ya registrado para validar el error 409."
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "ciudadano_id",
      "value": ""
    },
    {
      "key": "adeudo_id",
      "value": ""
    }
  ]
}
